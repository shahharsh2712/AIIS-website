# Public site URL (no trailing slash) — used for metadata and legal page footers
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend: https://resend.com — create API key, verify sending domain for production
RESEND_API_KEY=re_xxxxxxxx

# From address: use Resend's onboarding@resend.dev only for testing (to your own inbox).
# For production, verify a domain in Resend and use e.g. "AIIS <enquiries@yourdomain.com>"
RESEND_FROM=AIIS Enquiries <onboarding@resend.dev>

# Where enquiry emails are delivered (defaults to site email if unset)
ADMISSIONS_TO_EMAIL=shahharsh2712@gmail.com
